# Menggunakan image PHP 8.2 dengan Apache
FROM php:8.2-apache

# 1. Install ekstensi PHP yang diperlukan Laravel dan PostgreSQL
RUN apt-get update && apt-get install -y \
    libpq-dev \
    && docker-php-ext-install pdo pdo_pgsql pgsql

# 2. Aktifkan mod rewrite Apache (untuk routing Laravel)
RUN a2enmod rewrite

# 3. Setel direktori root Apache ke folder /public Laravel
#    (Langkah ini penting agar server langsung membaca index.php dari folder public)
RUN sed -i 's|DocumentRoot /var/www/html|DocumentRoot /var/www/html/public|' /etc/apache2/sites-available/000-default.conf

# 4. Set working directory
WORKDIR /var/www/html

# 5. Copy semua file project ke dalam container
COPY . /var/www/html

# 6. Beri izin write pada folder storage dan bootstrap/cache
RUN chmod -R 777 storage bootstrap/cache

# 7. Expose port 80
EXPOSE 80

# 8. Jalankan Apache di foreground
CMD ["apache2-foreground"]